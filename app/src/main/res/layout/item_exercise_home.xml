<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_unselected"
    android:padding="16dp">

    <View
        android:id="@+id/v_status_indicator"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/primary_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_exercise_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Push ups"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/iv_check"
        app:layout_constraintStart_toEndOf="@id/v_status_indicator"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_exercise_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="5 min • Chest"
        android:textColor="@color/white"
        android:alpha="0.5"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/tv_exercise_name"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_name" />

    <!-- Exercise progress bar -->
    <ProgressBar
        android:id="@+id/pb_exercise_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:progress="40"
        android:max="100"
        android:progressTint="@color/primary_green"
        android:progressBackgroundTint="#20FFFFFF"
        app:layout_constraintEnd_toStartOf="@id/tv_exercise_progress_text"
        app:layout_constraintStart_toStartOf="@id/tv_exercise_name"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_details" />

    <TextView
        android:id="@+id/tv_exercise_progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="2/5 min"
        android:textColor="@color/white"
        android:alpha="0.7"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/pb_exercise_progress"
        app:layout_constraintEnd_toStartOf="@id/iv_check"
        app:layout_constraintTop_toTopOf="@id/pb_exercise_progress" />

    <ImageView
        android:id="@+id/iv_check"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/checkbox_on_background"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/primary_green" />

</androidx.constraintlayout.widget.ConstraintLayout>