<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_unselected"
    android:padding="16dp">

    <!-- Document Name (Category) on top -->
    <TextView
        android:id="@+id/tv_exercise_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SHOULDERS"
        android:textColor="@color/primary_green"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Field Name (Exercise Name) -->
    <TextView
        android:id="@+id/tv_exercise_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Shoulder press"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/btn_start_exercise"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_category" />

    <!-- Minutes -->
    <TextView
        android:id="@+id/tv_exercise_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="10 min"
        android:textColor="@color/white"
        android:alpha="0.6"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_exercise_name" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_start_exercise"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/bg_get_started"
        android:text="START"
        android:textColor="@color/bg_dark"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>